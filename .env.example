# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public site
VITE_SITE_URL=https://livfunctional.com
VITE_DEFAULT_LOCALE=en

# Stripe — publishable key only on the client.
# Secret + webhook secret live as Supabase Edge Function secrets, not here.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# ---- Supabase Edge Function secrets (server-side only) -----------------------
# Set with:  supabase secrets set RESEND_API_KEY=... RESEND_FROM=... ADMIN_NOTIFY_EMAIL=...
#
# RESEND_API_KEY=re_xxx
# RESEND_FROM=Liv Functional <no-reply@livfunctional.com>
# RESEND_REPLY_TO=hello@livfunctional.com
# ADMIN_NOTIFY_EMAIL=team@livfunctional.com
